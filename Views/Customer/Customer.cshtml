@{
}
@model CareProjct.web.Models.Customer

<body class="bg-primary bg-white ">
    <div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-14 col-md-10 col-lg-7">
                    <div class="bg-white rounded-3 shadow p-4 p-sm-5">
                        <!-- Logo or Brand Name -->
                        <div class="text-center mb-4">

                            <h4> <p class="text-primary">Please Submit Your Details</p> </h4>
                        </div>

                        <!-- Login Form -->
                        <form asp-action="Customer" method="post" asp-controller="Customer">
                            <div class="mb-3">
                                <label class="form-label">ID</label>
                                <input type="number" class="form-control form-control-lg" asp-for="ID">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Full Name</label>
                                <input type="text" class="form-control form-control-lg" asp-for="FullName">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Address</label>
                                <div class="form-floating">
                                    <textarea class="form-control"  asp-for="Address"></textarea>

                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">City</label>
                                <div class="form-floating">
                                    <select class="form-select"  asp-for="City">
                                        <option>select your city</option>
                                        <option value="1">Kolhapur</option>
                                        <option value="2">Pune</option>
                                        <option value="3">Gargoti</option>
                                    </select>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email</label>
                                <input type="text" class="form-control form-control-lg" asp-for="Email">
                            </div>
                      
@*                              <div class="mb-3">
                                <label class="form-label">Contact Number</label>
                                <input type="number" class="form-control form-control-lg" asp-for="ContactNumber" >
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Service Type</label>

                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" asp-for="ServiceType">
                                    <label class="form-check-label" for="flexCheckDefault" >
                                        Baby Sitter
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" value="" asp-for="ServiceType">
                                    <label class="form-check-label" for="flexCheckChecked">
                                        Old-age care
                                    </label>
                                </div>  
                            </div> 

    *@
                             <button type="submit" class="btn btn-primary w-100 py-3">Submit</button>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="D:\class\bootstrap b1/js/bootstrap.bundle.min.js"></script>
    
</body>  


