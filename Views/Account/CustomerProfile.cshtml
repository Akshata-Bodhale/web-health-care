@model CareProjct.web.Models.CustomerProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div style="background:#f8fafc; min-height:100vh; padding:40px 0;">
<div class="container">

    <!-- Header -->
    <div style="background:linear-gradient(135deg,#1a3c5e,#2d7dd2); border-radius:16px; padding:36px 40px; color:white; margin-bottom:28px; display:flex; align-items:center; gap:24px; flex-wrap:wrap;">
        <div style="width:80px; height:80px; background:rgba(255,255,255,.2); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:2.4rem; flex-shrink:0;">
            👤
        </div>
        <div>
            <h2 style="font-weight:800; margin:0 0 4px;">@Model.FullName</h2>
            <p style="opacity:.85; margin:0; font-size:.95rem;">@Model.Email</p>
            <span style="background:rgba(255,255,255,.2); border-radius:20px; padding:4px 14px; font-size:.8rem; margin-top:8px; display:inline-block;">
                Customer Account
            </span>
        </div>
    </div>

    <div class="row g-4">

        <!-- Profile Details -->
        <div class="col-md-4">
            <div style="background:#fff; border-radius:14px; padding:28px; border:1px solid #e2e8f0; height:100%;">
                <h5 style="font-weight:700; color:#1a3c5e; margin-bottom:20px; border-bottom:2px solid #dbeafe; padding-bottom:10px;">
                    📋 Personal Info
                </h5>
                <div class="mb-3">
                    <label style="font-size:.8rem; color:#94a3b8; font-weight:600; text-transform:uppercase; letter-spacing:1px;">Full Name</label>
                    <div style="font-weight:600; color:#1e293b; margin-top:4px;">@Model.FullName</div>
                </div>
                <div class="mb-3">
                    <label style="font-size:.8rem; color:#94a3b8; font-weight:600; text-transform:uppercase; letter-spacing:1px;">Email</label>
                    <div style="font-weight:600; color:#1e293b; margin-top:4px;">@Model.Email</div>
                </div>
                
                
                <a asp-controller="Account" asp-action="MyBookings"
                   style="display:block; background:#1a3c5e; color:#fff; text-align:center; padding:12px; border-radius:8px; text-decoration:none; font-weight:600;">
                    📅 View My Bookings
                </a>
            </div>
        </div>

        <!-- Booking History -->
        <div class="col-md-8">
            <div style="background:#fff; border-radius:14px; padding:28px; border:1px solid #e2e8f0;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; border-bottom:2px solid #dbeafe; padding-bottom:10px;">
                    <h5 style="font-weight:700; color:#1a3c5e; margin:0;">📅 Booking History</h5>
                    <a asp-controller="Account" asp-action="BookNurse"
                       style="background:#dbeafe; color:#1d4ed8; padding:8px 16px; border-radius:8px; text-decoration:none; font-size:.85rem; font-weight:600;">
                        + New Booking
                    </a>
                </div>

                @if (!Model.BookingHistory.Any())
                {
                    <div style="text-align:center; padding:48px 24px; color:#94a3b8;">
                        <div style="font-size:3rem; margin-bottom:16px;">📋</div>
                        <p style="font-size:1.1rem; font-weight:600; color:#475569; margin-bottom:8px;">No bookings yet</p>
                        <p style="font-size:.9rem; margin-bottom:24px;">Your booking history will appear here once you make a booking.</p>
                        <a asp-controller="Account" asp-action="BookNurse"
                           style="background:#1a3c5e; color:#fff; padding:12px 28px; border-radius:8px; text-decoration:none; font-weight:600;">
                            Browse Caretakers
                        </a>
                    </div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table class="table" style="margin:0;">
                            <thead>
                                <tr style="background:#f8fafc;">
                                    <th style="color:#64748b; font-size:.8rem; font-weight:600; text-transform:uppercase; padding:12px 16px;">#</th>
                                    <th style="color:#64748b; font-size:.8rem; font-weight:600; text-transform:uppercase; padding:12px 16px;">Caretaker</th>
                                    <th style="color:#64748b; font-size:.8rem; font-weight:600; text-transform:uppercase; padding:12px 16px;">Service</th>
                                    <th style="color:#64748b; font-size:.8rem; font-weight:600; text-transform:uppercase; padding:12px 16px;">Date</th>
                                    <th style="color:#64748b; font-size:.8rem; font-weight:600; text-transform:uppercase; padding:12px 16px;">Amount</th>
                                    <th style="color:#64748b; font-size:.8rem; font-weight:600; text-transform:uppercase; padding:12px 16px;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var b in Model.BookingHistory)
                                {
                                    var statusColor = b.Status switch {
                                        "Confirmed" => "#dcfce7",
                                        "Pending"   => "#fef3c7",
                                        "Rejected"  => "#fee2e2",
                                        _           => "#f1f5f9"
                                    };
                                    var statusText = b.Status switch {
                                        "Confirmed" => "#166534",
                                        "Pending"   => "#92400e",
                                        "Rejected"  => "#991b1b",
                                        _           => "#475569"
                                    };
                                    <tr style="border-bottom:1px solid #f1f5f9;">
                                        <td style="padding:14px 16px; color:#64748b;">#@b.BookingId</td>
                                        <td style="padding:14px 16px; font-weight:600; color:#1e293b;">@b.NurseName</td>
                                        <td style="padding:14px 16px; color:#475569;">@b.ServiceType</td>
                                        <td style="padding:14px 16px; color:#475569;">@b.BookingDate.ToString("dd MMM yyyy")</td>
                                        <td style="padding:14px 16px; font-weight:700; color:#1a3c5e;">₹@b.TotalAmount</td>
                                        <td style="padding:14px 16px;">
                                            <span style="background:@statusColor; color:@statusText; padding:4px 12px; border-radius:20px; font-size:.8rem; font-weight:600;">
                                                @b.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

    </div>
</div>
</div>