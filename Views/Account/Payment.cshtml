}
@model CareProjct.web.Models.PaymentInfo
<h4>Payment Details</h4>
<body class="bg-primary bg-white ">
    <div class="min-vh-100 d-flex align-items-center justify-content-center py-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-14 col-md-10 col-lg-7">
                    <div class="bg-white rounded-3 shadow p-4 p-sm-5">
                        <!-- Logo or Brand Name -->
                        <div class="text-center mb-4">

                           
                        </div>
<form asp-action="Payment" method="post" asp-controller="Home">
  

    <div class="form-group">
        <label class="control-label">Cardholder Name</label>
        <input asp-for="CardholderName" class="form-control" />
        <span asp-validation-for="CardholderName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label class="control-label">Card Number</label>
        <input asp-for="CardNumber" class="form-control" />
        <span asp-validation-for="CardNumber" class="text-danger"></span>
    </div>

    <div class="form-row">
        <div class="form-group col-md-6">
            <label class="control-label">Expiration Date (MM/YY)</label>
            <input asp-for="ExpirationDate" class="form-control" placeholder="MM/YY" type="date" />
            <span asp-validation-for="ExpirationDate" class="text-danger"></span>
        </div>
        <div class="form-group col-md-6">
            <label class="control-label">CVV</label>
            <input asp-for="CVV" class="form-control" />
            <span asp-validation-for="CVV" class="text-danger"></span>
        </div>
    </div>
    <div class="form-group">
        <label class="control-label">Amount</label>
        <input asp-for="Amount" class="form-control" />
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="control-label">ReceiptEmail</label>
        <input asp-for="ReceiptEmail" class="form-control" />
        <span asp-validation-for="ReceiptEmail" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label class="control-label">BillingZip</label>
        <input asp-for="BillingZip" class="form-control" />
        <span asp-validation-for="BillingZip" class="text-danger"></span>
    </div>

    <div class="form-group mt-3">
        <button type="submit" class="btn btn-primary btn-lg btn-block">Place Order</button>
    </div>
</form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="D:\class\bootstrap b1/js/bootstrap.bundle.min.js"></script>
</body>

 

