@{
}

@model List<CareProjct.web.Models.CartItem>
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-5">
    <h2 class="mb-4">Shopping Cart</h2>

    @if (Model.Count == 0)
    {
        <p class="text-muted">Your cart is empty.</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Product Name</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><img src="@item.ImagePath" style="width: 80px; height: 80px;" /></td>
                        <td>@item.FullName</td>
                        <td>₹@item.Price</td>
                        <td>@item.Quantity</td>
                        <td>₹@(item.Price * item.Quantity)</td>
                        <td>
                            <a href="@Url.Action("RemoveFromCart", "Account", new { id = item.ID })" class="btn btn-danger btn-sm">Remove</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <h4 class="text-end">Total: ₹@Model.Sum(x => x.Price * x.Quantity)</h4>

        <div class="text-end">
            <a href="@Url.Action("Checkout", "Account")" class="btn btn-success">Proceed to Checkout</a>
        </div>
        <div class="text-start mt-4">
            <a href="@Url.Action("CaretakerProfile", "Caretaker")" class="btn btn-primary">
                ← Continue Shopping
            </a>
        </div>
    }
</div>