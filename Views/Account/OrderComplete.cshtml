@{
}
@model OrderConfirm // Replace with your actual model namespace


<div class="container py-5">
    <div class="card border-success">
        <div class="card-header bg-success text-white">
            <h2 class="mb-0">Order Confirmed!</h2>
        </div>
        <div class="card-body">
            <div class="text-center mb-4">
                <i class="fas fa-check-circle text-success" style="font-size: 64px;"></i>
            </div>

            <h3 class="card-title text-center mb-4">Thank you for your order!</h3>

            <div class="row">
                <div class="col-md-6">
                    <h5>Order Information</h5>
                    <p><strong>Order Number:</strong> @Model.OrderId</p>
                    <p><strong>Date:</strong> @Model.OrderDate</p>
                    <p><strong>Order Status:</strong> @Model.ProductDetails</p>
                    <p><strong>Payment Status:</strong> @Model.PaymentStatus</p>
                </div>
                <div class="col-md-6">
                    <h5>Customer Information</h5>
                    <p><strong>Name:</strong> @Model.CardHolderName</p>
                    <p><strong>Email:</strong> @Model.CardHolderName</p>
                    <p><strong>Phone:</strong> @Model.Method</p>
                </div>
            </div>

            <hr />

            <div class="text-center mt-4">
                <p class="mb-4">A confirmation email has been sent to <strong>@Model.OrderStatus</strong>.</p>
                <a asp-action="DownloadReceipt" asp-route-confirmationId="@Model.Id" class="btn btn-primary btn-lg">
                    <i class="fas fa-download"></i> Download Receipt
                </a>
            </div>
        </div>
        <div class="card-footer text-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                Continue Shopping
            </a>
        </div>
    </div>
</div>
 