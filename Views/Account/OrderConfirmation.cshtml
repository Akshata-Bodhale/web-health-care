@model CareProjct.web.Models.OrderConfirm

@{
    ViewData["Title"] = "Order Confirmation";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3>Order Confirmation</h3>
                </div>
                <div class="card-body">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5>Booking Summary</h5>
                            <p><strong>Booking ID:</strong> @Model.OrderId</p>
                            <p><strong> Booking Date:</strong> @Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</p>
                            <p><strong>Total Amount:</strong> $@Model.TotalAmount.ToString("F2")</p>
                            <p><strong>Status:</strong> <span class="badge bg-warning">@Model.OrderStatus</span></p>
                        </div>
                        <div class="col-md-6">
                            <h5>Customer Information</h5>
                            <p><strong>Name:</strong> @Model.FullName</p>
                            <p><strong>Address:</strong> @Model.Address</p>
                            <p><strong>City:</strong> @Model.City</p>
                            <p><strong>State:</strong> </p> 
                            <p><strong>Service Type:</strong> @Model.Country</p>
                            <p><strong>ZipCode:</strong> @Model.ZipCode</</p>
                        </div>

                        <div class="col-md-6">
                            <h5>Caretaker Information</h5>
                            <p><strong>Name:</strong> @Model.FullName</p>
                            <p><strong>Address:</strong> @Model.Address</p>
                            <p><strong>City:</strong> @Model.City</p>
                            <p><strong>State:</strong> </p>
                            <p><strong>Service Type:</strong> @Model.Country</p>
                            
                        </div>
                    </div>

                    <hr />

                    <h5>Complete Your Payment</h5>
                    <form asp-action="ProcessPayment" asp-controller="Home" method="post">
                        <input type="hidden" asp-for="OrderId" />
                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="TotalAmount" />
                        <input type="hidden" asp-for="FullName" />
                        <input type="hidden" asp-for="Address" />
                        <input type="hidden" asp-for="City" />
                        <input type="hidden" />
                        <input type="hidden" asp-for="ZipCode" />
                        <input type="hidden" asp-for="Country" />
                        <input type="hidden" asp-for="PhoneNumber" />
                        <input type="hidden" asp-for="Method" />
                        <input type="hidden" asp-for="Cost" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Shipping Method</label>
                                <select class="form-select" asp-for="Method" onchange="updateShippingCost()">
                                    <option value="Standard" data-cost="5.00">Standard Shipping ($5.00)</option>
                                    <option value="Express" data-cost="15.00">Express Shipping ($15.00)</option>
                                    <option value="Overnight" data-cost="25.00">Overnight Shipping ($25.00)</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Card Holder Name</label>
                                <input type="text" class="form-control" asp-for="CardHolderName" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Card Number</label>
                                <input type="text" class="form-control" id="cardNumber" placeholder="1234 5678 9012 3456" required
                                       pattern="[0-9\s]{13,19}" maxlength="19" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Expiration Month</label>
                                <select class="form-select" id="expirationMonth" required>
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <option value="@i.ToString("D2")">@i.ToString("D2")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Expiration Year</label>
                                <select class="form-select" id="expirationYear" required>
                                    @for (int i = DateTime.Now.Year; i <= DateTime.Now.Year + 10; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">CVV</label>
                                <input type="text" class="form-control" id="cvv" placeholder="123"
                                       required pattern="[0-9]{3,4}" maxlength="4" />
                            </div>
                        </div>

                        <div class="row mt-4">
                            <div class="col-md-12">
                                <div class="alert alert-info">
                                    <h5>Order Total</h5>
                                    <div class="d-flex justify-content-between">
                                        <span>Subtotal:</span>
                                        <span>$@Model.TotalAmount.ToString("F2")</span>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <span>Shipping:</span>
                                        <span id="shippingCostDisplay">$@Model.Cost.ToString("F2")</span>
                                    </div>
                                    <hr />
                                    <div class="d-flex justify-content-between fw-bold">
                                        <span>Total:</span>
                                        <span id="totalDisplay">$@((Model.TotalAmount + Model.Cost).ToString("F2"))</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg">Complete Order</button>
                            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">Continue Shopping</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
    function updateShippingCost() {
        const shippingSelect = document.querySelector('[asp-for="ShippingMethod"]');
        const selectedOption = shippingSelect.options[shippingSelect.selectedIndex];
        const shippingCost = parseFloat(selectedOption.getAttribute('data-cost'));

        document.querySelector('[asp-for="ShippingCost"]').value = shippingCost;
        document.getElementById('shippingCostDisplay').textContent = '$' + shippingCost.toFixed(2);

        const subtotal = @Html.Raw(Json.Serialize(Model.TotalAmount));
        const total = subtotal + shippingCost;
        document.getElementById('totalDisplay').textContent = '$' + total.toFixed(2);
    }

    document.addEventListener('DOMContentLoaded', function () {
        // Format credit card number with spaces
        const cardNumberInput = document.getElementById('cardNumber');
        cardNumberInput.addEventListener('input', function (e) {
            let value = e.target.value.replace(/\s+/g, '');
            if (value.length > 0) {
                value = value.match(new RegExp('.{1,4}', 'g')).join(' ');
            }
            e.target.value = value;
        });

        // On form submit, store last 4 digits
        const form = document.querySelector('form');
        form.addEventListener('submit', function (e) {
            const cardNumber = cardNumberInput.value.replace(/\s+/g, '');
            const lastFour = cardNumber.slice(-4);

            const hiddenInput = document.createElement('input');
            hiddenInput.type = 'hidden';
            hiddenInput.name = 'CardLastFourDigits';
            hiddenInput.value = lastFour;
            form.appendChild(hiddenInput);
        });
    });
</script>
