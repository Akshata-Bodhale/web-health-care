@model CareProjct.web.Models.Caretaker

<style>
    :root { --primary: #36625a; --accent: #f8b84c; --bg: #f5f0e3; --light: rgba(54,98,90,0.08); }
    body { background: var(--bg); }
    .profile-wrap { max-width: 1050px; margin: 40px auto; padding: 0 20px; }

    /* Top Profile Card */
    .profile-top { background: white; border-radius: 16px; padding: 35px; box-shadow: 0 5px 25px rgba(0,0,0,0.08); display: flex; gap: 35px; align-items: flex-start; margin-bottom: 30px; flex-wrap: wrap; }
    .profile-photo { width: 160px; height: 160px; border-radius: 50%; object-fit: cover; border: 4px solid var(--accent); flex-shrink: 0; }
    .profile-info { flex: 1; min-width: 250px; }
    .profile-name { color: var(--primary); font-weight: 800; font-size: 1.8rem; margin-bottom: 6px; }
    .profile-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 15px; }
    .badge-verified { background: #28a745; color: white; padding: 4px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
    .badge-category { background: var(--accent); color: white; padding: 4px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
    .badge-avail { background: var(--light); color: var(--primary); padding: 4px 14px; border-radius: 20px; font-size: 0.8rem; font-weight: 700; }
    .profile-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-top: 15px; }
    .meta-item label { font-size: 0.78rem; color: #999; display: block; }
    .meta-item strong { color: var(--primary); font-size: 0.95rem; }
    .price-box { text-align: center; background: var(--light); border-radius: 12px; padding: 20px 30px; flex-shrink: 0; }
    .price-amount { font-size: 2rem; font-weight: 800; color: var(--primary); }
    .price-label { color: #888; font-size: 0.85rem; }

    /* Booking Form */
    .booking-section { background: white; border-radius: 16px; padding: 35px; box-shadow: 0 5px 25px rgba(0,0,0,0.08); }
    .section-title { color: var(--primary); font-weight: 700; font-size: 1.2rem; border-bottom: 2px solid var(--accent); padding-bottom: 10px; margin-bottom: 25px; }
    .form-label { color: var(--primary); font-weight: 600; font-size: 0.88rem; }
    .form-control, .form-select { border: 1px solid rgba(54,98,90,0.2); border-radius: 8px; padding: 10px 14px; }
    .form-control:focus, .form-select:focus { border-color: var(--primary); box-shadow: 0 0 0 0.2rem rgba(54,98,90,0.15); }
    .price-summary { background: #f8f9fa; border-radius: 10px; padding: 20px; margin: 20px 0; }
    .price-row-summary { display: flex; justify-content: space-between; padding: 6px 0; font-size: 0.9rem; color: #666; }
    .price-row-total { display: flex; justify-content: space-between; padding: 10px 0 0; border-top: 1px solid #ddd; margin-top: 6px; font-weight: 700; color: var(--primary); font-size: 1.05rem; }
    .agree-box { background: #f8f9fa; border-left: 4px solid var(--accent); border-radius: 8px; padding: 15px 20px; margin: 20px 0; }
    .agree-text { font-size: 0.82rem; color: #666; max-height: 80px; overflow-y: auto; background: white; padding: 10px; border-radius: 6px; margin-bottom: 10px; border: 1px solid #ddd; }
    .btn-book { background: var(--primary); color: white; border: none; border-radius: 10px; padding: 14px; font-weight: 700; width: 100%; font-size: 1.05rem; cursor: pointer; margin-top: 10px; }
    .btn-book:hover { background: #2a4e47; }
    .login-prompt { background: #fff3cd; border: 1px solid #ffc107; border-radius: 10px; padding: 20px; text-align: center; margin-top: 20px; }
    .login-prompt a { color: var(--primary); font-weight: 700; }
</style>

<div class="profile-wrap">

    <!-- Profile Top -->
    <div class="profile-top">
        <img src="@Model.ImagePath" class="profile-photo" alt="@Model.FullName">

        <div class="profile-info">
            <div class="profile-name">@Model.FullName</div>
            <div class="profile-badges">
                <span class="badge-verified">✅ Verified Nurse</span>
                <span class="badge-category">Elder Care</span>
                @if (Model.Available)
                {
                    <span class="badge-avail">🟢 Available</span>
                }
                else
                {
                    <span style="background:#f8d7da;color:#721c24;padding:4px 14px;border-radius:20px;font-size:0.8rem;font-weight:700;">🔴 Currently Busy</span>
                }
            </div>

            <div class="profile-meta">
                <div class="meta-item">
                    <label>Qualification</label>
                    <strong>@Model.Qualification</strong>
                </div>
                <div class="meta-item">
                    <label>Experience</label>
                    <strong>@Model.Experience</strong>
                </div>
                <div class="meta-item">
                    <label>City</label>
                    <strong>📍 @Model.City</strong>
                </div>
                <div class="meta-item">
                    <label>Gender</label>
                    <strong>@Model.Gender</strong>
                </div>
                <div class="meta-item">
                    <label>License No.</label>
                    <strong>@Model.LicenseNumber</strong>
                </div>
                <div class="meta-item">
                    <label>Category</label>
                    <strong>Elder Care Specialist</strong>
                </div>
            </div>
        </div>

        <div class="price-box">
            <div class="price-amount">₹@Model.Price</div>
            <div class="price-label">per day</div>
            <div style="margin-top:10px;font-size:0.8rem;color:#888;">
                ~₹@(Model.Price * 30)/month<br>
                ~₹@(Model.Price * 7)/week
            </div>
        </div>
    </div>

    <!-- Booking Form -->
    <div class="booking-section">
        <div class="section-title">📋 Book This Nurse</div>

        @if (Context.Session.GetString("userId") == null)
        {
            <div class="login-prompt">
                <div style="font-size:2rem;margin-bottom:10px;">🔒</div>
                <strong>Please login to book this nurse</strong>
                <p class="text-muted mt-2 mb-3">You need to be logged in as a customer to make a booking.</p>
                <a href="/Home/Login" style="background:var(--primary);color:white;padding:10px 25px;border-radius:8px;text-decoration:none;font-weight:700;">
                    Login Now
                </a>
            </div>
        }
        else if (Context.Session.GetString("UserType") != "Customer")
        {
            <div class="login-prompt">
                <strong>Only customers can book nurses.</strong>
                <p class="text-muted mt-2">Please login as a customer to make a booking.</p>
            </div>
        }
        else
        {
            <form asp-action="BookNurse" asp-controller="Account" method="post">
                <input type="hidden" name="CaretakerId" value="@Model.ID">
                <input type="hidden" name="CaretakerName" value="@Model.FullName">
                <input type="hidden" name="PricePerDay" value="@Model.Price">

                <!-- Step 1: Patient Details -->
                <div class="section-title" style="font-size:1rem;">Step 1 — Patient Details</div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Patient Full Name *</label>
                        <input type="text" class="form-control" name="PatientName"
                            placeholder="Name of the person to be cared for" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Patient Age *</label>
                        <input type="number" class="form-control" name="PatientAge"
                            placeholder="Age in years" min="1" max="120" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Patient Condition *</label>
                    <select class="form-select" name="PatientCondition" required>
                        <option value="">Select the care needed</option>
                        <option value="Post-Surgery Recovery">Post-Surgery Recovery</option>
                        <option value="Elderly Bedridden">Elderly Bedridden</option>
                        <option value="Dementia Care">Dementia Care</option>
                        <option value="General Elderly Assistance">General Elderly Assistance</option>
                        <option value="Newborn Care">Newborn Care</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Special Notes for Nurse (Optional)</label>
                    <textarea class="form-control" name="PatientNotes" rows="2"
                        placeholder="e.g. Patient is diabetic, needs insulin twice daily..."></textarea>
                </div>

                <!-- Step 2: Service Details -->
                <div class="section-title" style="font-size:1rem;margin-top:25px;">Step 2 — Service Details</div>
                <div class="mb-3">
                    <label class="form-label">Service Address *</label>
                    <textarea class="form-control" name="ServiceAddress" rows="2"
                        placeholder="Full address where nurse will come" required></textarea>
                </div>
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Start Date *</label>
                        <input type="date" class="form-control" name="StartDate"
                            id="startDate" required
                            min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">End Date *</label>
                        <input type="date" class="form-control" name="EndDate"
                            id="endDate" required
                            min="@DateTime.Now.AddDays(2).ToString("yyyy-MM-dd")">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Number of Days</label>
                        <input type="text" class="form-control" id="numDays"
                            readonly style="background:#f8f9fa;font-weight:700;color:var(--primary);"
                            placeholder="Auto calculated">
                        <input type="hidden" name="NumberOfDays" id="numDaysHidden">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Shift Type *</label>
                    <select class="form-select" name="ShiftType" required>
                        <option value="">Select shift</option>
                        <option value="Day (8am-8pm)">Day Shift (8am – 8pm) — 12 hours</option>
                        <option value="Night (8pm-8am)">Night Shift (8pm – 8am) — 12 hours</option>
                        <option value="Full 24 Hours">Full 24 Hours</option>
                    </select>
                </div>

                <!-- Step 3: Emergency Contact -->
                <div class="section-title" style="font-size:1rem;margin-top:25px;">Step 3 — Your Contact Details</div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Your Full Name *</label>
                        <input type="text" class="form-control" name="FullName"
                            placeholder="Person booking the service" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Your Phone Number *</label>
                        <input type="tel" class="form-control" name="PhoneNumber"
                            placeholder="10 digit mobile number" required>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Emergency Contact Name *</label>
                        <input type="text" class="form-control" name="EmergencyContactName"
                            placeholder="Name of emergency contact" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Emergency Contact Phone *</label>
                        <input type="tel" class="form-control" name="EmergencyContactPhone"
                            placeholder="Emergency phone number" required>
                    </div>
                </div>

                <!-- Price Summary -->
                <div style="display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;">
                    <div style="background:#dcfce7;color:#166534;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:700;">
                        🗓️ Book 7+ days → <strong>10% OFF</strong>
                    </div>
                    <div style="background:#dbeafe;color:#1d4ed8;border-radius:8px;padding:8px 14px;font-size:0.82rem;font-weight:700;">
                        📅 Book 30+ days → <strong>20% OFF</strong>
                    </div>
                </div>
                <div class="price-summary">
                    <strong style="color:var(--primary);display:block;margin-bottom:10px;">Price Summary</strong>
                    <div class="price-row-summary">
                        <span>Daily Rate</span>
                        <span>₹@Model.Price / day</span>
                    </div>
                    <div class="price-row-summary">
                        <span>Number of Days</span>
                        <span id="summaryDays">0 days</span>
                    </div>
                    <div class="price-row-summary">
                        <span>Subtotal</span>
                        <span id="summarySubtotal">₹0</span>
                    </div>
                    <div class="price-row-summary" id="discountRow" style="display:none;color:#16a34a;font-weight:600;">
                        <span id="discountLabel">Discount</span>
                        <span id="discountAmount">-₹0</span>
                    </div>
                    <div class="price-row-summary">
                        <span>Platform Fee</span>
                        <span>₹50</span>
                    </div>
                    <div class="price-row-total">
                        <span>Total Amount</span>
                        <span id="summaryTotal">₹0</span>
                    </div>
                    <input type="hidden" name="TotalAmount" id="totalAmountHidden">
                </div>

                <!-- Step 4: Payment Method -->
                <div class="section-title" style="font-size:1rem;margin-top:25px;">Step 4 — Payment Preference</div>
                <div class="mb-3">
                    <label class="form-label">How would you prefer to pay? *</label>
                    <select class="form-select" name="PaymentMethod"
                            id="paymentMethod" onchange="showPaymentNote()" required>
                        <option value="">Select payment method</option>
                        <option value="Cash">💵 Cash</option>
                        <option value="UPI">📱 UPI</option>
                        <option value="Bank Transfer">🏦 Bank Transfer</option>
                    </select>
                </div>
                <div id="paymentNote" style="display:none;border-radius:8px;padding:12px 16px;margin-bottom:15px;font-size:0.85rem;"></div>


                
                <!-- Agreement -->
                <div class="agree-box">
                    <strong style="color:var(--primary);">Booking Terms & Cancellation Policy</strong>
                    <div class="agree-text">
                        By confirming this booking you agree to the following terms:
                        Free cancellation is allowed up to 48 hours before the service start date.
                        50% refund is applicable if cancelled within 24 hours of start date.
                        No refund on same day cancellation or after service has started.
                        The platform connects families with verified nurses and is not responsible
                        for medical outcomes. You agree to treat the nurse with respect and dignity.
                        Direct hiring of this nurse outside the platform after this contact is
                        strictly prohibited and violates our terms of service.
                        Payment will be released to the nurse 48 hours after service completion
                        unless a dispute is raised.
                    </div>
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox"
                            name="AcceptedBookingTerms" value="true" required id="bookingTerms">
                        <label class="form-check-label" for="bookingTerms" style="font-size:0.85rem;">
                            <strong>I have read and accept the Booking Terms and Cancellation Policy</strong>
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn-book">
                    ✅ Confirm Booking Request — ₹<span id="btnTotal">0</span>
                </button>
                <p class="text-center text-muted mt-2" style="font-size:0.82rem;">
                    The nurse will receive your request and confirm within 24 hours.
                    Payment is collected at confirmation.
                </p>
            </form>
        }
    </div>
</div>
<script>
    const pricePerDay = @Model.Price;

    function calculateTotal() {
        const start = document.getElementById('startDate').value;
        const end   = document.getElementById('endDate').value;

        if (start && end) {
            const s    = new Date(start);
            const e    = new Date(end);
            const diff = Math.ceil((e - s) / (1000 * 60 * 60 * 24));

            if (diff > 0) {
                const subtotal = diff * pricePerDay;

                let discountPct   = 0;
                let discountLabel = '';
                if (diff >= 30) {
                    discountPct   = 20;
                    discountLabel = '📅 Monthly Discount (20% off)';
                } else if (diff >= 7) {
                    discountPct   = 10;
                    discountLabel = '🗓️ Weekly Discount (10% off)';
                }

                const discountAmt = Math.round(subtotal * discountPct / 100);
                const total       = subtotal - discountAmt + 50;

                document.getElementById('numDays').value               = diff + ' days';
                document.getElementById('numDaysHidden').value         = diff;
                document.getElementById('summaryDays').textContent     = diff + ' days';
                document.getElementById('summarySubtotal').textContent = '₹' + subtotal;
                document.getElementById('summaryTotal').textContent    = '₹' + total;
                document.getElementById('totalAmountHidden').value     = total;
                document.getElementById('btnTotal').textContent        = total;

                const discountRow = document.getElementById('discountRow');
                if (discountAmt > 0) {
                    discountRow.style.display = 'flex';
                    document.getElementById('discountLabel').textContent  = discountLabel;
                    document.getElementById('discountAmount').textContent = '-₹' + discountAmt;
                } else {
                    discountRow.style.display = 'none';
                }
            }
        }
    }

    document.getElementById('startDate').addEventListener('change', calculateTotal);
    document.getElementById('endDate').addEventListener('change', calculateTotal);

    function showPaymentNote() {
        const method = document.getElementById('paymentMethod').value;
        const note   = document.getElementById('paymentNote');
        const msgs   = {
            'Cash':          { bg:'#fff3cd', color:'#856404', text:'💵 You will pay the nurse in cash on the service start date.' },
            'UPI':           { bg:'#d1ecf1', color:'#0c5460', text:'📱 The nurse will share their UPI ID after confirming the booking.' },
            'Bank Transfer': { bg:'#d4edda', color:'#155724', text:'🏦 The nurse will share bank details after confirming the booking.' }
        };
        if (msgs[method]) {
            note.style.display    = 'block';
            note.style.background = msgs[method].bg;
            note.style.color      = msgs[method].color;
            note.textContent      = msgs[method].text;
        } else {
            note.style.display = 'none';
        }
    }
</script>