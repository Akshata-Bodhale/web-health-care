 @model List<CareProjct.web.Models.Caretaker>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Caretaker Profiles</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        .card {
            border: 2px solid #007bff;
            border-radius: 10px;
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .card:hover {
            transform: scale(1.05);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
        }
        .card img {
            border-radius: 50%;
            display: block;
            margin: 15px auto;
        }
        .card-body {
            text-align: center;
        }
        .card-title {
            color: #007bff;
            font-weight: bold;
        }
        .btn-profile {
            background-color: #007bff;
            color: white;
            padding: 8px 15px;
            border-radius: 5px;
            text-decoration: none;
            display: inline-block;
            margin-top: 10px;
            transition: background 0.3s ease;
        }
        .btn-profile:hover {
            background-color: #0056b3;
            color: white;
        }
    </style>
</head>
<body>
     <form method="get" action="/Caretaker/CaretakerData" class="d-flex">
        <select name="category" class="form-select me-2" onchange="this.form.submit()">
            <option value="">Select Category</option>

            @if (ViewBag.Categories != null)
            {
                foreach (var cat in ViewBag.Categories)
                {
                    if (cat != null)
                    {
                        if (ViewBag.SelectedCategory != null && cat.ToString() == ViewBag.SelectedCategory.ToString())
                        {
                            <option value="@cat" selected>@cat</option>
                        }
                        else
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                }
            }
        </select>
        <button type="submit" class="btn btn-primary">Filter</button>
    </form>
    <div class="container mt-5">
        <h2 class="mb-4 text-center">Caretaker Profiles</h2>
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card p-3">
                        <img src="@item.ImagePath" height="90px" width="90px" alt="Profile Picture">
                        <div class="card-body">
                            <h5 class="card-title">@item.FullName</h5>
                            <p class="card-text"><strong>City:</strong> @item.City</p>
                            
                            <p class="card-text"><strong>Service Type:</strong> @item.Category</p>
                            <a href="@Url.Action("CaretakerProfile", "Caretaker", new { Id = item.ID })" class="btn-profile">View Profile</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div> 

   
</body>
</html> 


