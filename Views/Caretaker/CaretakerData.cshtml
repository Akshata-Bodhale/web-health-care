@model IEnumerable<CareProjct.web.Models.Caretaker>

<style>
    :root {
        --primary: #36625a;
        --accent: #f8b84c;
        --bg: #f5f0e3;
        --light: rgba(54,98,90,0.08);
    }
    body { background: var(--bg); }
    .page-wrap { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
    .page-header { text-align: center; margin-bottom: 40px; }
    .page-header h2 { color: var(--primary); font-weight: 700; font-size: 2rem; margin-bottom: 8px; }
    .page-header p { color: #888; font-size: 1rem; }
    .underline { width: 60px; height: 3px; background: var(--accent); margin: 10px auto 15px; border-radius: 2px; }

    /* Filter Bar */
    .filter-bar { background: white; border-radius: 12px; padding: 20px 25px; box-shadow: 0 3px 15px rgba(0,0,0,0.06); margin-bottom: 35px; display: flex; gap: 15px; flex-wrap: wrap; align-items: center; }
    .filter-bar select { border: 1px solid rgba(54,98,90,0.2); border-radius: 8px; padding: 10px 15px; color: var(--primary); font-size: 0.92rem; flex: 1; min-width: 180px; }
    .filter-bar select:focus { outline: none; border-color: var(--primary); }
    .btn-filter { background: var(--primary); color: white; border: none; border-radius: 8px; padding: 10px 25px; font-weight: 600; cursor: pointer; white-space: nowrap; }
    .btn-filter:hover { background: #2a4e47; }
    .btn-clear { background: white; color: var(--primary); border: 1px solid var(--primary); border-radius: 8px; padding: 10px 20px; font-weight: 600; cursor: pointer; text-decoration: none; white-space: nowrap; font-size: 0.9rem; }

    /* Cards Grid */
    .nurses-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: 25px; }
    .nurse-card { background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 5px 20px rgba(0,0,0,0.07); transition: all 0.3s ease; position: relative; }
    .nurse-card:hover { transform: translateY(-6px); box-shadow: 0 15px 35px rgba(0,0,0,0.12); }

    .card-image { height: 210px; overflow: hidden; position: relative; }
    .card-image img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
    .nurse-card:hover .card-image img { transform: scale(1.05); }

    .verified-badge { position: absolute; top: 12px; left: 12px; background: #28a745; color: white; font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; }
    .category-badge { position: absolute; top: 12px; right: 12px; background: var(--accent); color: white; font-size: 0.75rem; font-weight: 700; padding: 4px 12px; border-radius: 20px; }

    .card-body { padding: 22px; }
    .card-body h3 { color: var(--primary); font-size: 1.2rem; font-weight: 700; margin-bottom: 14px; }

    .card-details { display: flex; flex-direction: column; gap: 9px; margin-bottom: 18px; }
    .detail-row { display: flex; align-items: center; gap: 10px; }
    .detail-icon { width: 28px; height: 28px; background: var(--light); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--primary); font-size: 0.78rem; flex-shrink: 0; }
    .detail-label { font-size: 0.78rem; color: #999; display: block; }
    .detail-value { font-size: 0.9rem; color: var(--primary); font-weight: 600; }

    .price-row { display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f0f0f0; padding-top: 15px; margin-bottom: 15px; }
    .price-tag { font-size: 1.3rem; font-weight: 800; color: var(--primary); }
    .price-tag span { font-size: 0.78rem; font-weight: 400; color: #999; }
    .exp-tag { background: var(--light); color: var(--primary); padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; }

    .btn-view { display: block; background: var(--primary); color: white; text-align: center; padding: 12px; border-radius: 8px; font-weight: 700; text-decoration: none; transition: all 0.2s; font-size: 0.95rem; }
    .btn-view:hover { background: #2a4e47; color: white; }

    /* Empty state */
    .empty-box { text-align: center; padding: 70px 20px; background: white; border-radius: 15px; }
    .empty-box .icon { font-size: 3.5rem; margin-bottom: 20px; }
    .empty-box h3 { color: var(--primary); font-weight: 700; }
    .empty-box p { color: #888; }

    /* Result count */
    .result-count { color: #888; font-size: 0.9rem; margin-bottom: 20px; }
    .result-count strong { color: var(--primary); }
</style>

<div class="page-wrap">

    <!-- Header -->
    <div class="page-header">
        <h2>Find Your Elder Care Nurse</h2>
        <div class="underline"></div>
        <p>Browse verified and approved nurses for in-home elder care services</p>
    </div>

    <!-- Filter Bar -->
    <form method="get" action="/Caretaker/CaretakerData" class="filter-bar">
        <select name="city">
            <option value="">📍 All Cities</option>
            @if (ViewBag.Cities != null)
            {
                foreach (var c in ViewBag.Cities)
                {
                    if (c != null)
                    {
                        <option value="@c"
                            selected="@(ViewBag.SelectedCity != null &&
                                        c.ToString() == ViewBag.SelectedCity.ToString()
                                        ? "selected" : null)">
                            @c
                        </option>
                    }
                }
            }
        </select>

        <select name="gender">
            <option value="">👤 Any Gender</option>
            <option value="Female"
                selected="@(ViewBag.SelectedGender == "Female" ? "selected" : null)">
                Female Nurse
            </option>
            <option value="Male"
                selected="@(ViewBag.SelectedGender == "Male" ? "selected" : null)">
                Male Nurse
            </option>
        </select>

        <select name="maxPrice">
            <option value="">💰 Any Price</option>
            <option value="800"
                selected="@(ViewBag.SelectedPrice == "800" ? "selected" : null)">
                Up to ₹800/day
            </option>
            <option value="1000"
                selected="@(ViewBag.SelectedPrice == "1000" ? "selected" : null)">
                Up to ₹1000/day
            </option>
            <option value="1200"
                selected="@(ViewBag.SelectedPrice == "1200" ? "selected" : null)">
                Up to ₹1200/day
            </option>
            <option value="1500"
                selected="@(ViewBag.SelectedPrice == "1500" ? "selected" : null)">
                Up to ₹1500/day
            </option>
        </select>

        <button type="submit" class="btn-filter">🔍 Search</button>
        <a href="/Caretaker/CaretakerData" class="btn-clear">✕ Clear</a>
    </form>

    <!-- Result Count -->
    @if (Model != null && Model.Any())
    {
        <div class="result-count">
            Showing <strong>@Model.Count()</strong> verified nurse(s) available for elder care
        </div>

        <!-- Nurses Grid -->
        <div class="nurses-grid">
            @foreach (var item in Model)
            {
                <div class="nurse-card">
                    <div class="card-image">
                        <img src="@item.ImagePath" alt="@item.FullName">
                        <span class="verified-badge">✅ Verified</span>
                        <span class="category-badge">Elder Care</span>
                    </div>
                    <div class="card-body">
                        <h3>@item.FullName</h3>
                        <div class="card-details">
                            <div class="detail-row">
                                <div class="detail-icon">
                                    <i class="fas fa-map-marker-alt"></i>
                                </div>
                                <div>
                                    <span class="detail-label">City</span>
                                    <div class="detail-value">@item.City</div>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-icon">
                                    <i class="fas fa-graduation-cap"></i>
                                </div>
                                <div>
                                    <span class="detail-label">Qualification</span>
                                    <div class="detail-value">
                                        @(item.Qualification?.Length > 28
                                            ? item.Qualification.Substring(0, 25) + "..."
                                            : item.Qualification)
                                    </div>
                                </div>
                            </div>
                            <div class="detail-row">
                                <div class="detail-icon">
                                    <i class="@(item.Gender == "Female" ? "fas fa-female" : "fas fa-male")"></i>
                                </div>
                                <div>
                                    <span class="detail-label">Gender</span>
                                    <div class="detail-value">@item.Gender</div>
                                </div>
                            </div>
                        </div>
                        <div class="price-row">
                            <div class="price-tag">
                                ₹@item.Price <span>/ day</span>
                            </div>
                            <span class="exp-tag">@item.Experience</span>
                        </div>
                        <a href="@Url.Action("CaretakerProfile","Caretaker",new{ID=item.ID})"
                           class="btn-view">
                            View Full Profile & Book
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-box">
            <div class="icon">🔍</div>
            <h3>No Nurses Found</h3>
            <p>Try changing your filters or check back later for new profiles.</p>
            <a href="/Caretaker/CaretakerData" class="btn-view d-inline-block mt-3"
               style="max-width:200px;">View All Nurses</a>
        </div>
    }

</div>