@model CareProjct.web.Models.Caretaker

<style>
    :root { --primary: #36625a; --accent: #f8b84c; --bg: #f5f0e3; }
    body { background: var(--bg); font-family: 'Segoe UI', sans-serif; }
    .edit-wrap { max-width: 720px; margin: 40px auto; padding: 0 20px; }
    .page-title { color: var(--primary); font-weight: 700; font-size: 1.6rem; margin-bottom: 5px; }
    .page-sub { color: #888; margin-bottom: 30px; font-size: 0.9rem; }

    .card { background: white; border-radius: 14px; padding: 30px; box-shadow: 0 4px 18px rgba(0,0,0,0.07); margin-bottom: 25px; }
    .card-title { color: var(--primary); font-weight: 700; font-size: 1rem; border-bottom: 2px solid var(--accent); padding-bottom: 10px; margin-bottom: 20px; }

    .form-group { margin-bottom: 18px; }
    .form-group label { display: block; font-size: 0.82rem; color: #666; font-weight: 600; margin-bottom: 6px; }
    .form-group input { width: 100%; padding: 10px 14px; border: 1.5px solid #e0e0e0; border-radius: 8px; font-size: 0.92rem; transition: border 0.2s; box-sizing: border-box; }
    .form-group input:focus { border-color: var(--primary); outline: none; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }

    /* Photo preview */
    .photo-section { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; }
    .photo-preview { width: 90px; height: 90px; border-radius: 50%; object-fit: cover; border: 3px solid var(--accent); }
    .photo-upload-btn { background: var(--bg); border: 1.5px dashed var(--primary); color: var(--primary); padding: 8px 18px; border-radius: 8px; cursor: pointer; font-size: 0.85rem; font-weight: 600; }

    /* Lock badge */
    .locked-note { background: #fff3cd; border-radius: 8px; padding: 12px 16px; font-size: 0.83rem; color: #856404; margin-bottom: 20px; }

    .btn-save { background: var(--primary); color: white; border: none; border-radius: 10px; padding: 13px 35px; font-weight: 700; font-size: 1rem; cursor: pointer; width: 100%; margin-top: 5px; }
    .btn-save:hover { background: #2a4f48; }
    .btn-cancel { display: block; text-align: center; margin-top: 12px; color: #888; font-size: 0.88rem; text-decoration: none; }
    .btn-cancel:hover { color: var(--primary); }

    .alert-success { background: #d4edda; color: #155724; border-radius: 8px; padding: 12px 16px; margin-bottom: 20px; font-weight: 600; }

    @@media (max-width: 600px) { .two-col { grid-template-columns: 1fr; } }
</style>

<div class="edit-wrap">
    <div class="page-title">✏️ Edit Profile</div>
    <div class="page-sub">Update your contact info, photo, pricing, and bank details.</div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert-success">✅ @TempData["SuccessMessage"]</div>
    }

    <div class="locked-note">
        🔒 <strong>Qualification, license, and verification documents</strong> cannot be edited here.
        Contact admin if these need to be updated.
    </div>

    <form asp-action="EditProfile" asp-controller="Caretaker" method="post" enctype="multipart/form-data">

        <!-- Profile Photo -->
        <div class="card">
            <div class="card-title">📷 Profile Photo</div>
            <div class="photo-section">
                <img id="photoPreview"
                     src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/default-nurse.png" : Model.ImagePath)"
                     class="photo-preview" alt="Profile Photo" />
                <div>
                    <label class="photo-upload-btn" for="ImageFile">📁 Choose New Photo</label>
                    <input type="file" id="ImageFile" name="ImageFile" accept="image/*"
                           style="display:none;" onchange="previewPhoto(this)" />
                    <div style="font-size:0.78rem;color:#aaa;margin-top:6px;">JPG, PNG — max 2MB</div>
                </div>
            </div>
        </div>

        <!-- Personal Info -->
        <div class="card">
            <div class="card-title">👤 Personal Information</div>
            <div class="two-col">
                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="FullName" value="@Model.FullName" required />
                </div>
                <div class="form-group">
                    <label>Contact Number</label>
                    <input type="text" name="ContactNumber" value="@Model.ContactNumber" required />
                </div>
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>City</label>
                    <input type="text" name="City" value="@Model.City" />
                </div>
                <div class="form-group">
                    <label>Price per Day (₹)</label>
                    <input type="number" name="Price" value="@Model.Price" min="0" step="50" required />
                </div>
            </div>
            <div class="form-group">
                <label>Full Address</label>
                <input type="text" name="Address" value="@Model.Address" />
            </div>
        </div>

        <!-- Bank Details -->
        <div class="card">
            <div class="card-title">🏦 Bank Details</div>
            <div class="two-col">
                <div class="form-group">
                    <label>Account Holder Name</label>
                    <input type="text" name="AccountHolderName" value="@Model.AccountHolderName" />
                </div>
                <div class="form-group">
                    <label>Bank Name</label>
                    <input type="text" name="BankName" value="@Model.BankName" />
                </div>
            </div>
            <div class="two-col">
                <div class="form-group">
                    <label>Account Number</label>
                    <input type="text" name="BankAccountNumber" value="@Model.BankAccountNumber" />
                </div>
                <div class="form-group">
                    <label>IFSC Code</label>
                    <input type="text" name="IFSCCode" value="@Model.IFSCCode" />
                </div>
            </div>
        </div>

        <button type="submit" class="btn-save">💾 Save Changes</button>
        <a href="/Caretaker/MyDashboard" class="btn-cancel">← Cancel and go back</a>

    </form>
</div>

<script>
    function previewPhoto(input) {
        if (input.files && input.files[0]) {
            var reader = new FileReader();
            reader.onload = function (e) {
                document.getElementById('photoPreview').src = e.target.result;
            };
            reader.readAsDataURL(input.files[0]);
        }
    }
</script>