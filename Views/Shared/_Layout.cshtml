<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Elder Care</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CareProjct.web.styles.css" asp-append-version="true" />
    <script src="https://kit.fontawesome.com/a076d05399.js" crossorigin="anonymous"></script>

    <style>
        :root {
            --primary: #36625a;
            --accent: #f8b84c;
            --bg: #f5f0e3;
        }

        body {
            background: var(--bg);
            font-family: 'Segoe UI', sans-serif;
        }

        /* ── Navbar ── */
        .navbar {
            background: white !important;
            box-shadow: 0 2px 15px rgba(0,0,0,0.08);
            padding: 12px 0;
        }

        .navbar-brand {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--primary) !important;
        }

        .nav-link {
            font-size: 0.88rem;
            font-weight: 500;
            color: #444 !important;
            padding: 6px 10px !important;
            border-radius: 6px;
            transition: all 0.2s ease;
        }

        .nav-link:hover {
            background: rgba(54,98,90,0.08);
            color: var(--primary) !important;
        }

        .nav-link.active {
            color: var(--primary) !important;
            font-weight: 600;
        }

        .btn-nav-login {
            background: var(--primary);
            color: white !important;
            border-radius: 8px;
            padding: 8px 20px !important;
            font-weight: 600 !important;
        }

        .btn-nav-login:hover {
            background: #2a4e47 !important;
            color: white !important;
        }

        .btn-nav-logout {
            background: #dc3545;
            color: white !important;
            border-radius: 8px;
            padding: 8px 16px !important;
            font-weight: 600 !important;
            font-size: 0.88rem !important;
        }

        .btn-nav-logout:hover {
            background: #b02a37 !important;
            color: white !important;
        }

        .user-badge {
            background: rgba(54,98,90,0.1);
            color: var(--primary) !important;
            border-radius: 8px;
            font-weight: 600 !important;
            font-size: 0.88rem !important;
        }

        .dropdown-menu {
            border: none;
            border-radius: 10px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.12);
            padding: 8px;
        }

        .dropdown-item {
            border-radius: 6px;
            padding: 9px 14px;
            font-size: 0.9rem;
            transition: all 0.2s;
        }

        .dropdown-item:hover {
            background: rgba(54,98,90,0.08);
            color: var(--primary);
        }

        /* ── Footer ── */
        .main-footer {
            background: #1e3a35;
            color: #ccc;
            padding: 40px 0 0;
            margin-top: 60px;
        }

        .footer-brand {
            font-size: 1.3rem;
            font-weight: 800;
            color: white;
            margin-bottom: 10px;
        }

        .footer-desc {
            font-size: 0.88rem;
            color: #aaa;
            line-height: 1.7;
        }

        .footer-heading {
            color: var(--accent);
            font-weight: 700;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 15px;
        }

        .footer-link {
            color: #aaa;
            text-decoration: none;
            font-size: 0.88rem;
            display: block;
            padding: 4px 0;
            transition: all 0.2s;
        }

        .footer-link:hover {
            color: var(--accent);
            padding-left: 5px;
        }

        .footer-contact-item {
            font-size: 0.88rem;
            color: #aaa;
            margin-bottom: 8px;
        }

        .footer-contact-item i {
            color: var(--accent);
            width: 18px;
        }

        .footer-bottom {
            background: #152e29;
            padding: 15px 0;
            margin-top: 30px;
            font-size: 0.82rem;
            color: #888;
        }

        /* ── Alerts ── */
        .alert-success-bar {
            background: #d4edda;
            color: #155724;
            padding: 12px 20px;
            border-radius: 0;
            font-size: 0.9rem;
            border-bottom: 1px solid #c3e6cb;
        }

        .alert-danger-bar {
            background: #f8d7da;
            color: #721c24;
            padding: 12px 20px;
            border-radius: 0;
            font-size: 0.9rem;
            border-bottom: 1px solid #f5c6cb;
        }
    </style>
</head>

<body>

<!-- ══════════════════════════════════════
     NAVBAR
══════════════════════════════════════ -->
<nav class="navbar navbar-expand-lg sticky-top px-2">
    <style>
        .navbar .navbar-nav { gap: 2px; }
        .navbar-brand { margin-right: 30px; }
    </style>
    <div class="container">

        <!-- Brand -->
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            🏥 Elder<span style="color:var(--accent);">Care</span>
        </a>

        <!-- Mobile toggle -->
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse justify-content-between" id="navbarNav">

            <!-- Left links — always visible -->
            <!-- Left links -->
<ul class="navbar-nav me-auto">

    @* Public links — hidden from Admin *@
    @if (Context.Session.GetString("UserType") != "Admin")
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Home" asp-action="Index">
                <i class="fas fa-home me-1"></i> Home
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Home" asp-action="ElderCareService">
                <i class="fas fa-hand-holding-heart me-1"></i> Elder Care
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Home" asp-action="AboutUs">
                <i class="fas fa-info-circle me-1"></i> About Us
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" asp-controller="Home" asp-action="DisplayFeedbacks">
                <i class="fas fa-quote-left me-1"></i> Testimonials
            </a>
        </li>
    }

    @* Customer browse link *@
    @if (Context.Session.GetString("UserType") == "Customer")
    {
        <li class="nav-item">
            <a class="nav-link" asp-controller="Caretaker" asp-action="CaretakerData">
                <i class="fas fa-search me-1"></i> Browse Nurses
            </a>
        </li>
    }  

                @if (Context.Session.GetString("UserType") == "Admin")
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminBoard" asp-action="AdminDashboard">
                            <i class="fas fa-th-large me-1"></i> Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminBoard" asp-action="VerificationQueue">
                            <i class="fas fa-user-check me-1"></i> Verify Nurses
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminBoard" asp-action="AllBookings">
                            <i class="fas fa-calendar-alt me-1"></i> All Bookings
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="AdminBoard" asp-action="Payments">
                            <i class="fas fa-money-bill-wave me-1"></i> Payments
                        </a>
                    </li>
                }
            </ul>

            <!-- Right links — change based on login state -->
            <ul class="navbar-nav ms-auto align-items-center gap-1">

                @* ══ NOT LOGGED IN ══ *@
                @if (Context.Session.GetString("userId") == null)
                {
                    <li class="nav-item">
                        <a class="nav-link btn-nav-login"
                           asp-controller="Home" asp-action="Login">
                            <i class="fas fa-sign-in-alt me-1"></i> Login / Register
                        </a>
                    </li>
                }

                @* ══ CUSTOMER LOGGED IN ══ *@
                else if (Context.Session.GetString("UserType") == "Customer")
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link user-badge dropdown-toggle"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-circle me-1"></i>
                            @Context.Session.GetString("UserName")
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <span class="dropdown-item-text text-muted"
                                      style="font-size:0.8rem;padding:6px 14px;">
                                    Logged in as Customer
                                </span>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Caretaker"
                                   asp-action="CaretakerData">
                                    <i class="fas fa-search me-2"
                                       style="color:var(--primary);"></i>
                                    Browse Nurses
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Account"
                                   asp-action="MyBookings">
                                    <i class="fas fa-calendar-check me-2"
                                       style="color:var(--primary);"></i>
                                    My Bookings
                                </a>
                                <li>
                                    <a class="dropdown-item"
                                    asp-controller="Home"
                                    asp-action="Feedback">
                                        <i class="fas fa-star me-2"
                                        style="color:var(--primary);"></i>
                                        Give Feedback
                                    </a>
                                </li>
                            </li>
                            <li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Account"
                                   asp-action="CustomerProfile">
                                    <i class="fas fa-id-card me-2"
                                       style="color:var(--primary);"></i>
                                    My Profile
                                </a>
                            </li>
                            <hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item text-danger"
                                   asp-controller="Home" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>
                                    Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                }

                @* ══ CARETAKER LOGGED IN ══ *@
                else if (Context.Session.GetString("UserType") == "Caretaker")
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link user-badge dropdown-toggle"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-nurse me-1"></i>
                            @Context.Session.GetString("UserName")
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <span class="dropdown-item-text text-muted"
                                      style="font-size:0.8rem;padding:6px 14px;">
                                    Logged in as Nurse
                                </span>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Caretaker"
                                   asp-action="MyDashboard">
                                    <i class="fas fa-calendar-alt me-2"
                                       style="color:var(--primary);"></i>
                                    My Appointments
                                </a>
                            </li>

                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item"
                                asp-controller="Caretaker"
                                asp-action="MyProfile">
                                    <i class="fas fa-id-card me-2"
                                    style="color:var(--primary);"></i>
                                    My Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="Caretaker"
                                   asp-action="EditProfile">
                                    <i class="fas fa-user-edit me-2"
                                       style="color:var(--primary);"></i>
                                    Edit Profile
                                </a>
                            </li>

                                                        <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item text-danger"
                                   asp-controller="Home" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>
                                    Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                }

                @* ══ ADMIN LOGGED IN ══ *@
                else if (Context.Session.GetString("UserType") == "Admin")
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle"
                           style="background:#dc3545;color:white !important;
                                  border-radius:8px;padding:8px 16px !important;
                                  font-weight:600 !important;"
                           href="#" role="button" data-bs-toggle="dropdown">
                            <i class="fas fa-user-shield me-1"></i> Admin
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <span class="dropdown-item-text text-muted"
                                      style="font-size:0.8rem;padding:6px 14px;">
                                    Admin Panel
                                </span>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminBoard"
                                   asp-action="AdminDashboard">
                                    <i class="fas fa-th-large me-2"
                                       style="color:var(--primary);"></i>
                                    Dashboard
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminBoard"
                                   asp-action="VerificationQueue">
                                    <i class="fas fa-user-check me-2"
                                       style="color:var(--primary);"></i>
                                    Verify Nurses
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminBoard"
                                   asp-action="AllBookings">
                                    <i class="fas fa-calendar-alt me-2"
                                       style="color:var(--primary);"></i>
                                    All Bookings
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-controller="AdminBoard"
                                   asp-action="ProductList">
                                    <i class="fas fa-users me-2"
                                       style="color:var(--primary);"></i>
                                    Manage Nurses
                                </a>
                            </li>
                            <li><hr class="dropdown-divider my-1"></li>
                            <li>
                                <a class="dropdown-item text-danger"
                                   asp-controller="Home" asp-action="Logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>
                                    Logout
                                </a>
                            </li>
                        </ul>
                    </li>
                }

            </ul>
        </div>
    </div>
</nav>

<!-- ══════════════════════════════════════
     FLASH MESSAGES
══════════════════════════════════════ -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success-bar text-center">
        ✅ @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-danger-bar text-center">
        ❌ @TempData["ErrorMessage"]
    </div>
}
@if (TempData["InfoMessage"] != null)
{
    <div style="background:#fff3cd;color:#856404;padding:12px 20px;
                text-align:center;font-size:0.9rem;
                border-bottom:1px solid #ffc107;">
        ℹ️ @TempData["InfoMessage"]
    </div>
}

<!-- ══════════════════════════════════════
     MAIN CONTENT
══════════════════════════════════════ -->
<main role="main" class="pb-3">
    @RenderBody()
</main>

<!-- ══════════════════════════════════════
     FOOTER
══════════════════════════════════════ -->
<footer class="main-footer">
    <div class="container">
        <div class="row">

            <!-- Brand Column -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="footer-brand">
                    🏥 Elder<span style="color:var(--accent);">Care</span>
                </div>
                <p class="footer-desc">
                    Providing trusted, verified in-home elder care services.
                    We connect families with qualified nurses to ensure your
                    loved ones receive the best care at home.
                </p>
                <div class="mt-3" style="display:flex;gap:10px;">
                    <a href="#" style="background:#2a4e47;color:#aaa;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.85rem;">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a href="#" style="background:#2a4e47;color:#aaa;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.85rem;">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="#" style="background:#2a4e47;color:#aaa;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;font-size:0.85rem;">
                        <i class="fab fa-whatsapp"></i>
                    </a>
                </div>
            </div>

            <!-- Quick Links -->
            <div class="col-lg-2 col-md-6 mb-4">
                <div class="footer-heading">Quick Links</div>
                <a class="footer-link" asp-controller="Home" asp-action="Index">Home</a>
                <a class="footer-link" asp-controller="Home" asp-action="ElderCareService">Elder Care Services</a>
                <a class="footer-link" asp-controller="Home" asp-action="AboutUs">About Us</a>
                <a class="footer-link" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            </div>

            <!-- For Users -->
            <div class="col-lg-2 col-md-6 mb-4">
                <div class="footer-heading">For Users</div>
                <a class="footer-link" asp-controller="Home" asp-action="Register">Register as Family</a>
                <a class="footer-link" asp-controller="Home" asp-action="CaretakerRegister">Join as Nurse</a>
                <a class="footer-link" asp-controller="Caretaker" asp-action="CaretakerData">Browse Nurses</a>
                <a class="footer-link" asp-controller="Home" asp-action="Login">Login</a>
                <a class="footer-link" asp-controller="Home" asp-action="DisplayFeedbacks">Testimonials</a>
                <a class="footer-link" asp-controller="Home" asp-action="Feedback">Give Feedback</a>
            </div>

            <!-- Contact -->
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="footer-heading">Contact Us</div>
                <div class="footer-contact-item">
                    <i class="fas fa-map-marker-alt"></i>
                    Kolhapur, Maharashtra, India
                </div>
                <div class="footer-contact-item">
                    <i class="fas fa-envelope"></i>
                    support@eldercare.com
                </div>
                <div class="footer-contact-item">
                    <i class="fas fa-phone"></i>
                    +91 98765 43210
                </div>
                <div class="footer-contact-item">
                    <i class="fas fa-clock"></i>
                    Mon–Sat: 9am – 7pm
                </div>
            </div>

        </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-center text-md-start">
                    &copy; 2025 ElderCare. All rights reserved.
                </div>
                <div class="col-md-6 text-center text-md-end">
                    <a class="footer-link d-inline me-3"
                       asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
                    <a class="footer-link d-inline"
                       asp-controller="Home" asp-action="AboutUs">Terms of Service</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>