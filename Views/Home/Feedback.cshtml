@model CareProjct.web.Models.FeedbackViewModel
@{
    ViewData["Title"] = "Give Feedback";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root { --primary: #36625a; --accent: #f8b84c; --bg: #f5f0e3; }

    .feedback-wrapper {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 50px 15px;
        background: var(--bg);
    }

    .feedback-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        width: 100%;
        max-width: 520px;
        padding: 45px 40px;
    }

    .form-label {
        color: var(--primary);
        font-weight: 600;
        font-size: 0.88rem;
        margin-bottom: 6px;
        display: block;
    }

    .form-control {
        width: 100%;
        padding: 11px 14px;
        border: 1px solid rgba(54,98,90,0.25);
        border-radius: 8px;
        font-size: 0.95rem;
        font-family: 'Segoe UI', sans-serif;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(54,98,90,0.12);
    }

    textarea.form-control {
        resize: vertical;
        min-height: 120px;
    }

    .mb-3 { margin-bottom: 18px; }

    .btn-submit {
        width: 100%;
        padding: 14px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 8px;
        font-weight: 700;
        font-size: 1rem;
        cursor: pointer;
        margin-top: 8px;
        transition: background 0.2s, transform 0.2s;
    }

    .btn-submit:hover {
        background: #2a4e47;
        transform: translateY(-2px);
    }
</style>

<div class="feedback-wrapper">
    <div class="feedback-card">

        <div class="text-center mb-4">
            <span style="background:var(--accent);color:#1e3a35;padding:5px 18px;border-radius:20px;font-size:0.8rem;font-weight:700;">
                Share Your Experience
            </span>
            <h2 style="color:var(--primary);font-weight:800;margin-top:14px;margin-bottom:4px;">
                Give Feedback
            </h2>
            <p style="color:#888;font-size:0.9rem;">
                Your feedback helps us improve our services
            </p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div style="background:#d4edda;color:#155724;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:0.9rem;">
                ✅ @TempData["SuccessMessage"]
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div style="background:#f8d7da;color:#721c24;border-radius:8px;padding:12px 16px;margin-bottom:20px;font-size:0.9rem;">
                ❌ @TempData["ErrorMessage"]
            </div>
        }

        <form asp-action="AboutUs" asp-controller="Home" method="post">

            <div class="mb-3">
                <label class="form-label">Your Full Name *</label>
                <input type="text" asp-for="FullName" class="form-control"
                       placeholder="Enter your full name" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Caretaker / Nurse Name *</label>
                <input type="text" asp-for="NurseName" class="form-control"
                       placeholder="Name of the caretaker you worked with" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Your Feedback *</label>
                <textarea asp-for="Description" class="form-control"
                          placeholder="Share your experience with us..." required></textarea>
            </div>

            <button type="submit" class="btn-submit">
                ⭐ Submit Feedback
            </button>

            <p class="text-center mt-3" style="font-size:0.85rem;color:#888;">
                Want to read others' experiences?
                <a asp-controller="Home" asp-action="DisplayFeedbacks"
                   style="color:var(--primary);font-weight:600;">
                    View Testimonials →
                </a>
            </p>

        </form>
    </div>
</div>