            opacity: 0.5;
        }
 */
        /* Container */
        .container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 30px;
            position: relative;
        }

        /* Header */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 40px;
        }
/* 
        .logo {
            font-size: 28px;
