<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TinyTots Babysitting Services</title>
    <style>
        /* Reset and Base Styles */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Quicksand', 'Helvetica Neue', sans-serif;
        }

        body {
            background-color: white;
            color: #4a4a4a;
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
        }

        /* Decorative Elements */
        .decoration {
            position: absolute;
            z-index: -1;
        }

        .circle-1 {
            top: -100px;
            right: -100px;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: linear-gradient(135deg, #ffd6e0, #ffacc7);
            opacity: 0.4;
        }

        .circle-2 {
            bottom: 100px;
            left: -150px;
            width: 400px;
            height: 400px;
            border-radius: 50%;
            background: linear-gradient(135deg, #c4f0ff, #a0d2f3);
            opacity: 0.3;
        }

