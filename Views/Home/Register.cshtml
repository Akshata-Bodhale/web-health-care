<style>
    :root { --primary: #36625a; --accent: #f8b84c; --bg: #f5f0e3; }
    body { background: var(--bg); font-family: 'Segoe UI', sans-serif; }
    .reg-wrapper { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 30px 15px; }
    .reg-card { background: white; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); padding: 45px 40px; width: 100%; max-width: 520px; }
    .reg-title { color: var(--primary); font-weight: 700; font-size: 1.6rem; text-align: center; margin-bottom: 5px; }
    .reg-sub { color: #888; text-align: center; font-size: 0.9rem; margin-bottom: 30px; }
    .form-label { color: var(--primary); font-weight: 600; font-size: 0.88rem; }
    .form-control { border: 1px solid rgba(54,98,90,0.25); border-radius: 8px; padding: 11px 14px; }
    .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 0.2rem rgba(54,98,90,0.15); }
    .btn-reg { background: var(--primary); color: white; border: none; border-radius: 8px; padding: 13px; font-weight: 700; width: 100%; font-size: 1rem; margin-top: 10px; }
    .btn-reg:hover { background: #2a4e47; }
    .agree-box { background: #f8f9fa; border-radius: 8px; padding: 15px; margin-bottom: 10px; }
    .agree-text { font-size: 0.82rem; color: #666; max-height: 80px; overflow-y: auto; background: white; padding: 8px; border-radius: 6px; margin-bottom: 8px; border: 1px solid #ddd; }
    .alert-danger { background: #f8d7da; color: #721c24; border-radius: 8px; padding: 12px 15px; margin-bottom: 20px; }
</style>

<div class="reg-wrapper">
    <div class="reg-card">

        <div class="text-center mb-3">
            <span style="background:var(--accent);color:white;padding:5px 18px;border-radius:20px;font-size:0.8rem;font-weight:700;">Customer Registration</span>
        </div>
        <div class="reg-title">Create Your Account</div>
        <div class="reg-sub">Register to book elder care services</div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-danger">❌ @TempData["ErrorMessage"]</div>
        }

        <form method="post" asp-action="Register" asp-controller="Home">

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">First Name *</label>
                    <input type="text" name="FirstName" class="form-control"
                        placeholder="First name" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Last Name *</label>
                    <input type="text" name="LastName" class="form-control"
                        placeholder="Last name" required>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Email Address *</label>
                <input type="email" name="Email" class="form-control"
                    placeholder="Your active email" required>
            </div>

            <div class="mb-3">
                <label class="form-label">Password *</label>
                <input type="password" name="Password" class="form-control"
                    placeholder="Minimum 8 characters" required minlength="8">
            </div>

            <!-- Agreement 1 -->
            <div class="agree-box">
                <strong style="color:var(--primary);font-size:0.88rem;">Terms and Conditions</strong>
                <div class="agree-text">
                    By registering on this platform you agree to use the service only for
                    legitimate home care purposes. You agree not to misuse the personal
                    information of any caretaker. All bookings must be made through the
                    platform. Direct hiring of a caretaker outside the platform after
                    contact through this platform is strictly prohibited. The platform
                    connects families with verified nurses and is not directly responsible
                    for medical outcomes. You agree to treat all caretakers with respect
                    and dignity at all times.
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                        name="AgreedToTerms" value="true" required id="terms">
                    <label class="form-check-label" for="terms" style="font-size:0.85rem;">
                        <strong>I agree to the Terms and Conditions</strong>
                    </label>
                </div>
            </div>

            <!-- Agreement 2 -->
            <div class="agree-box">
                <strong style="color:var(--primary);font-size:0.88rem;">Privacy Policy</strong>
                <div class="agree-text">
                    We collect your name, email, phone number, and patient details to
                    provide home care services. Your data will not be sold to third parties.
                    Patient medical information shared during booking is stored securely
                    and shared only with the assigned nurse. You have the right to request
                    deletion of your data at any time by contacting us.
                    Under India's DPDPA 2023, we are committed to protecting your
                    personal and health data.
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox"
                        name="AgreedToPrivacy" value="true" required id="privacy">
                    <label class="form-check-label" for="privacy" style="font-size:0.85rem;">
                        <strong>I agree to the Privacy Policy</strong>
                    </label>
                </div>
            </div>

            <button type="submit" class="btn-reg">Create Account</button>

            <p class="text-center text-muted mt-3" style="font-size:0.85rem;">
                Already have an account?
                <a href="/Home/Login" style="color:var(--primary);font-weight:600;">Login here</a>
            </p>
        </form>
    </div>
</div>