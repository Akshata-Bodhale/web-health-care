@{
    ViewData["Title"] = "Elder Care Services";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --ec-primary: #36625a;
        --ec-accent: #f8b84c;
        --ec-light: #f5f0e3;
    }

    .page-hero {
        background: linear-gradient(135deg, #36625a 0%, #4a8a7e 100%);
        padding: 60px 0;
        color: white;
        text-align: center;
    }

    .page-hero h1 {
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 12px;
    }

    .page-hero p {
        font-size: 1rem;
        opacity: 0.85;
        max-width: 520px;
        margin: 0 auto;
    }

    .page-hero .hero-tag {
        display: inline-block;
        background: rgba(248,184,76,0.2);
        color: var(--ec-accent);
        border: 1px solid rgba(248,184,76,0.35);
        padding: 5px 16px;
        border-radius: 50px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    /* Services Grid */
    .services-section {
        background: var(--ec-light);
        padding: 64px 0;
    }

    .section-eyebrow {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--ec-primary);
        margin-bottom: 8px;
    }

    .section-title {
        font-size: 1.9rem;
        font-weight: 800;
        color: #1e3a35;
        margin-bottom: 8px;
    }

    .section-sub {
        color: #888;
        font-size: 0.92rem;
        margin-bottom: 44px;
    }

    .service-card {
        background: white;
        border-radius: 16px;
        padding: 32px 24px;
        border: 1px solid #e8e0d0;
        height: 100%;
        transition: all 0.25s;
        position: relative;
        overflow: hidden;
    }

    .service-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
        background: var(--ec-primary);
        transform: scaleX(0);
        transition: transform 0.25s;
        transform-origin: left;
    }

    .service-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 16px 40px rgba(54,98,90,0.1);
        border-color: #b5d4cc;
    }

    .service-card:hover::before {
        transform: scaleX(1);
    }

    .service-icon {
        width: 60px;
        height: 60px;
        background: #e8f5f2;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.7rem;
        margin-bottom: 20px;
    }

    .service-title {
        font-size: 1.05rem;
        font-weight: 700;
        color: #1e3a35;
        margin-bottom: 10px;
    }

    .service-desc {
        font-size: 0.87rem;
        color: #777;
        line-height: 1.75;
        margin: 0;
    }

    /* Process Section */
    .process-section {
        background: white;
        padding: 64px 0;
    }

    .process-step {
        display: flex;
        gap: 20px;
        align-items: flex-start;
        margin-bottom: 32px;
    }

    .process-step:last-child { margin-bottom: 0; }

    .process-num {
        width: 44px;
        height: 44px;
        background: var(--ec-primary);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .process-title {
        font-size: 1rem;
        font-weight: 700;
        color: #1e3a35;
        margin-bottom: 4px;
    }

    .process-desc {
        font-size: 0.87rem;
        color: #777;
        line-height: 1.7;
        margin: 0;
    }

    .process-image {
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    .process-image img {
        width: 100%;
        height: 380px;
        object-fit: cover;
        display: block;
    }

    /* Pricing */
    .pricing-section {
        background: var(--ec-light);
        padding: 64px 0;
    }

    .price-card {
        background: white;
        border-radius: 16px;
        padding: 36px 28px;
        border: 1px solid #e8e0d0;
        height: 100%;
        text-align: center;
        transition: all 0.25s;
    }

    .price-card.featured {
        border: 2px solid var(--ec-primary);
        position: relative;
    }

    .price-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 16px 36px rgba(54,98,90,0.1);
    }

    .price-badge {
        position: absolute;
        top: -13px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--ec-accent);
        color: #1e3a35;
        font-size: 0.72rem;
        font-weight: 800;
        padding: 4px 14px;
        border-radius: 20px;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }

    .price-plan {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--ec-primary);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    .price-amount {
        font-size: 2.4rem;
        font-weight: 800;
        color: #1e3a35;
        line-height: 1;
        margin-bottom: 4px;
    }

    .price-period {
        font-size: 0.8rem;
        color: #999;
        margin-bottom: 24px;
    }

    .price-features {
        list-style: none;
        padding: 0;
        margin: 0 0 28px;
        text-align: left;
    }

    .price-features li {
        font-size: 0.88rem;
        color: #555;
        padding: 7px 0;
        border-bottom: 1px solid #f0ece2;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .price-features li:last-child { border-bottom: none; }

    .price-features li::before {
        content: '✓';
        color: var(--ec-primary);
        font-weight: 800;
        flex-shrink: 0;
    }

    .btn-book {
        display: block;
        background: var(--ec-primary);
        color: white;
        font-weight: 700;
        padding: 13px 24px;
        border-radius: 10px;
        text-decoration: none;
        font-size: 0.9rem;
        transition: background 0.2s;
        text-align: center;
    }

    .btn-book:hover {
        background: #2a4e47;
        color: white;
    }

    .btn-book.outline {
        background: transparent;
        border: 2px solid var(--ec-primary);
        color: var(--ec-primary);
    }

    .btn-book.outline:hover {
        background: var(--ec-primary);
        color: white;
    }

    /* CTA */
    .cta-section {
        background: linear-gradient(135deg, #1e3a35, #36625a);
        padding: 64px 0;
        text-align: center;
        color: white;
    }

    .cta-section h2 {
        font-size: 1.9rem;
        font-weight: 800;
        margin-bottom: 12px;
    }

    .cta-section p {
        opacity: 0.85;
        margin-bottom: 32px;
        max-width: 460px;
        margin-left: auto;
        margin-right: auto;
    }
</style>

<!-- ══ PAGE HERO ══ -->
<section class="page-hero">
    <div class="container">
        <div class="hero-tag">Our Services</div>
        <h1>🏥 Elder Care Services</h1>
        <p>Professional, compassionate, and verified caretakers — tailored to every senior's unique needs.</p>
    </div>
</section>

<!-- ══ SERVICES GRID ══ -->
<section class="services-section">
    <div class="container">
        <div class="text-center">
            <div class="section-eyebrow">What We Offer</div>
            <h2 class="section-title">Complete Care Solutions</h2>
            <p class="section-sub">Every service delivered by trained, background-verified professionals</p>
        </div>
        <div class="row g-4">
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">💊</div>
                    <div class="service-title">Medication Management</div>
                    <p class="service-desc">Timely reminders, dosage tracking, and coordination with doctors to ensure medications are never missed or doubled.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">🧘</div>
                    <div class="service-title">Physiotherapy Support</div>
                    <p class="service-desc">Guided physical exercises, mobility improvement routines, and post-surgery rehabilitation at home.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">🍽️</div>
                    <div class="service-title">Meal Preparation</div>
                    <p class="service-desc">Nutrition-focused, doctor-recommended meals prepared fresh daily according to dietary requirements.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">🚿</div>
                    <div class="service-title">Personal Hygiene Care</div>
                    <p class="service-desc">Bathing, grooming, dressing, and toileting assistance delivered with sensitivity and dignity.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">🧠</div>
                    <div class="service-title">Dementia & Memory Care</div>
                    <p class="service-desc">Specialist support for seniors with Alzheimer's, dementia, and other cognitive conditions requiring patient, structured care.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">🚗</div>
                    <div class="service-title">Mobility Assistance</div>
                    <p class="service-desc">Safe transfers, walking assistance, wheelchair support, and accompaniment to medical appointments.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">🩺</div>
                    <div class="service-title">Vital Signs Monitoring</div>
                    <p class="service-desc">Regular monitoring of blood pressure, sugar levels, and other vitals with daily reports to family members.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">💬</div>
                    <div class="service-title">Companionship Care</div>
                    <p class="service-desc">Emotional support, conversation, recreational activities, and social engagement to prevent loneliness.</p>
                </div>
            </div>
            <div class="col-md-4 col-sm-6">
                <div class="service-card">
                    <div class="service-icon">🌙</div>
                    <div class="service-title">Overnight & 24/7 Care</div>
                    <p class="service-desc">Round-the-clock care plans for seniors who need continuous supervision and assistance at all hours.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ HOW IT WORKS ══ -->
<section class="process-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <div class="section-eyebrow">Our Process</div>
                <h2 class="section-title">How We Ensure Quality Care</h2>
                <p class="section-sub" style="margin-bottom:36px;">Every caretaker goes through a rigorous process before serving your family</p>

                <div class="process-step">
                    <div class="process-num">1</div>
                    <div>
                        <div class="process-title">Application & Document Upload</div>
                        <p class="process-desc">Caretakers apply with professional credentials, Aadhaar, police clearance, and nursing license.</p>
                    </div>
                </div>
                <div class="process-step">
                    <div class="process-num">2</div>
                    <div>
                        <div class="process-title">Admin Verification</div>
                        <p class="process-desc">Our team reviews all documents and approves only qualified, trustworthy professionals.</p>
                    </div>
                </div>
                <div class="process-step">
                    <div class="process-num">3</div>
                    <div>
                        <div class="process-title">Profile Goes Live</div>
                        <p class="process-desc">Approved caretakers appear in our browse directory for families to view and book.</p>
                    </div>
                </div>
                <div class="process-step">
                    <div class="process-num">4</div>
                    <div>
                        <div class="process-title">Booking & Care Begins</div>
                        <p class="process-desc">Family books, caretaker confirms, and professional care begins at your doorstep.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="process-image">
                    <img src="/Images/care.jpg"
                         onerror="this.src='https://images.unsplash.com/photo-1559839734-2b71ea197ec2?w=700&q=80'"
                         alt="Caretaker with patient" />
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ══ PRICING ══ -->
<section class="pricing-section">
    <div class="container">
        <div class="text-center">
            <div class="section-eyebrow">Pricing</div>
            <h2 class="section-title">Simple, Transparent Pricing</h2>
            <p class="section-sub">No hidden fees — pay only for the care your loved one needs</p>
        </div>
        <div class="row g-4 justify-content-center">
            <div class="col-md-4">
                <div class="price-card">
                    <div class="price-plan">Basic</div>
                    <div class="price-amount">₹400</div>
                    <div class="price-period">per day · 4–6 hours</div>
                    <ul class="price-features">
                        <li>Medication reminders</li>
                        <li>Meal preparation</li>
                        <li>Personal hygiene</li>
                        <li>Basic vitals check</li>
                    </ul>
                    <a asp-controller="Caretaker" asp-action="CaretakerData" class="btn-book outline">
                        Browse Caretakers
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="price-card featured">
                    <div class="price-badge">Most Popular</div>
                    <div class="price-plan">Standard</div>
                    <div class="price-amount">₹700</div>
                    <div class="price-period">per day · 8–10 hours</div>
                    <ul class="price-features">
                        <li>Everything in Basic</li>
                        <li>Physiotherapy support</li>
                        <li>Mobility assistance</li>
                        <li>Companionship care</li>
                        <li>Daily family reports</li>
                    </ul>
                    <a asp-controller="Caretaker" asp-action="CaretakerData" class="btn-book">
                        Book Now
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="price-card">
                    <div class="price-plan">Premium</div>
                    <div class="price-amount">₹1,200</div>
                    <div class="price-period">per day · 24 hours</div>
                    <ul class="price-features">
                        <li>Everything in Standard</li>
                        <li>24/7 overnight care</li>
                        <li>Dementia specialist</li>
                        <li>Doctor coordination</li>
                        <li>Emergency response</li>
                    </ul>
                    <a asp-controller="Caretaker" asp-action="CaretakerData" class="btn-book outline">
                        Browse Caretakers
                    </a>
                </div>
            </div>
        </div>
        <p class="text-center mt-4" style="font-size:0.82rem;color:#999;">
            * Final pricing depends on the individual caretaker's rate. Browse profiles to see exact pricing.
        </p>
    </div>
</section>

<!-- ══ CTA ══ -->
<section class="cta-section">
    <div class="container">
        <h2>Find the Right Caretaker Today</h2>
        <p>Browse verified profiles and book a caretaker that fits your family's needs perfectly.</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Caretaker" asp-action="CaretakerData"
               style="background:var(--ec-accent);color:#1e3a35;font-weight:700;padding:14px 32px;border-radius:10px;text-decoration:none;font-size:0.95rem;">
                Browse Caretakers
            </a>
            <a asp-controller="Home" asp-action="Login"
               style="border:2px solid rgba(255,255,255,0.45);color:white;font-weight:600;padding:14px 28px;border-radius:10px;text-decoration:none;font-size:0.95rem;">
                Login / Register
            </a>
        </div>
    </div>
</section>