@{
    ViewData["Title"] = "About Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- HERO -->
<section style="background:linear-gradient(135deg,#1a3c5e,#2d7dd2); color:white; padding:64px 0; text-align:center;">
    <div class="container">
        <div style="font-size:56px; margin-bottom:16px;">❤️</div>
        <h1 style="font-size:2.4rem; font-weight:800; margin-bottom:12px;">About Elder Care</h1>
        <p style="font-size:1.1rem; opacity:.9; max-width:520px; margin:0 auto;">
            We bridge the gap between families who need care and professionals who provide it — with trust, transparency, and compassion.
        </p>
    </div>
</section>

<!-- MISSION -->
<section style="padding:64px 0; background:#fff;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <div style="font-size:.75rem; font-weight:700; color:#2d7dd2; letter-spacing:2px; margin-bottom:8px;">OUR MISSION</div>
                <h2 style="font-size:2rem; font-weight:800; color:#1a3c5e; margin-bottom:20px;">Care That Feels Like Family</h2>
                <p style="color:#475569; line-height:1.8; margin-bottom:16px;">
                    Elder Care was founded on the belief that every senior deserves dignified, professional, and compassionate support in the comfort of their own home.
                </p>
                <p style="color:#475569; line-height:1.8;">
                    Our platform connects verified caretakers with families, ensuring transparency at every step — from profile verification to booking confirmation.
                </p>
            </div>
            <div class="col-md-6">
                <div style="background:#f0f9ff; border-radius:20px; padding:40px; border:1px solid #bae6fd;">
                    <div class="row g-4 text-center">
                        @{
                            var stats = new[] {
                                new { Val="2019", Label="Founded" },
                                new { Val="500+", Label="Caretakers" },
                                new { Val="15+",  Label="Cities" },
                                new { Val="4.9★", Label="Rating" }
                            };
                        }
                        @foreach (var st in stats)
                        {
                            <div class="col-6">
                                <div style="font-size:1.8rem; font-weight:800; color:#1d4ed8;">@st.Val</div>
                                <div style="color:#64748b; font-size:.85rem; margin-top:4px;">@st.Label</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- VALUES -->
<section style="padding:64px 0; background:#f8fafc;">
    <div class="container">
        <h2 class="text-center fw-bold mb-2" style="color:#1a3c5e;">What We Stand For</h2>
        <p class="text-center text-muted mb-5">Our core values guide every decision we make</p>
        <div class="row g-4">
            @{
                var values = new[] {
                    new { Icon="✅", Title="Trust & Verification",  Desc="Every caretaker is background-checked and certified before joining our platform." },
                    new { Icon="🔒", Title="Privacy & Safety",      Desc="Your family's data is protected. We never share personal information without consent." },
                    new { Icon="🌟", Title="Quality of Care",       Desc="We maintain high standards through ongoing reviews and caretaker training." },
                    new { Icon="💬", Title="Open Communication",    Desc="Families can track, message, and rate their caretaker at every step of the journey." }
                };
            }
            @foreach (var v in values)
            {
                <div class="col-md-6">
                    <div style="background:#fff; border-radius:14px; padding:32px; border:1px solid #e2e8f0; display:flex; gap:20px; height:100%;">
                        <div style="font-size:2rem; flex-shrink:0;">@v.Icon</div>
                        <div>
                            <h5 style="font-weight:700; color:#1a3c5e; margin-bottom:8px;">@v.Title</h5>
                            <p style="color:#64748b; margin:0; line-height:1.7;">@v.Desc</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- TEAM -->
<section style="padding:64px 0; background:#fff;">
    <div class="container">
        <h2 class="text-center fw-bold mb-2" style="color:#1a3c5e;">Our Team</h2>
        <p class="text-center text-muted mb-5">Dedicated professionals passionate about elder care</p>
        <div class="row g-4 justify-content-center">
            @{
                var team = new[] {
                    new { Name="Dr. Priya Sharma",   Role="Medical Director",      Emoji="👩‍⚕️" },
                    new { Name="Rajesh Kumar",        Role="Operations Head",       Emoji="👨‍💼" },
                    new { Name="Anita Desai",         Role="Caretaker Relations",   Emoji="👩‍🤝‍👩" }
                };
            }
            @foreach (var t in team)
            {
                <div class="col-md-4">
                    <div style="background:#f8fafc; border-radius:16px; padding:36px 24px; text-align:center; border:1px solid #e2e8f0;">
                        <div style="font-size:3rem; margin-bottom:16px;">@t.Emoji</div>
                        <h5 style="font-weight:700; color:#1a3c5e; margin-bottom:4px;">@t.Name</h5>
                        <p style="color:#2d7dd2; font-size:.9rem; font-weight:600;">@t.Role</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- CTA -->
<section style="background:linear-gradient(135deg,#1a3c5e,#2d7dd2); padding:56px 0; color:white; text-align:center;">
    <div class="container">
        <h2 style="font-weight:800; font-size:1.8rem; margin-bottom:12px;">Have Questions? We're Here.</h2>
        <p style="opacity:.9; margin-bottom:28px;">Our support team is available 24/7 to help your family.</p>
        <a asp-controller="Home" asp-action="Login"
           style="background:#fff; color:#1a3c5e; font-weight:700; padding:14px 36px; border-radius:8px; text-decoration:none;">
            Get Started Today
        </a>
    </div>
</section>