@model List<CareProjct.web.Models.FeedbackViewModel>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Holmcare Services - Personalized Healthcare</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <style>
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background-color: #fff;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.1);
            z-index: 1000;
        }

            .navbar a {
                text-decoration: none;
                color: #000;
                margin: 0 15px;
                font-weight: bold;
            }

                .navbar a:hover {
                    color: #d63384;
                }

        /* Add margin to the body to prevent content from being hidden under the fixed navbar */
        .content {
            margin-top: 80px;
            padding: 20px;
        }
        .feature-icon {
            background-color: rgba(255, 105, 180, 0.1);
            border-radius: 50%;
            padding: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .learn-more-btn {
            transition: all 0.3s ease;
        }

            .learn-more-btn:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(255,105,180,0.3);
            }

        .stat-card {
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: transform 0.3s ease;
        }

            .stat-card:hover {
                transform: translateY(-10px);}

        body {
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
           
        }

        .about-container {
            text-align: center;
            max-width: 900px;
            padding: 40px;
            background-color: white;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-left:200px;
            margin-top: 150px;
        }

        .section-tag {
            color: #ff6b6b;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 14px;
            margin-bottom: 15px;
        }

        .main-headline {
            color: #2c3e50;
            font-size: 2.5rem;
            line-height: 1.3;
            margin-bottom: 20px;
        }

        .description {
            color: #7f8c8d;
            font-size: 1rem;
            line-height: 1.6;
        }
/*         feedback */
       



    </style>
</head>
<body class="bg-gray-50" class="bg-white">
