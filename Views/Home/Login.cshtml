<style>
    :root { --primary: #36625a; --accent: #f8b84c; --bg: #f5f0e3; }
    body { background: var(--bg); font-family: 'Segoe UI', sans-serif; }
    .login-wrapper { min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 30px 15px; }
    .login-card { background: white; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.1); padding: 45px 40px; width: 100%; max-width: 440px; }
    .login-title { color: var(--primary); font-weight: 700; font-size: 1.7rem; text-align: center; margin-bottom: 5px; }
    .login-sub { color: #888; text-align: center; font-size: 0.9rem; margin-bottom: 30px; }
    .form-label { color: var(--primary); font-weight: 600; font-size: 0.88rem; }
    .form-control { border: 1px solid rgba(54,98,90,0.25); border-radius: 8px; padding: 11px 14px; }
    .form-control:focus { border-color: var(--primary); box-shadow: 0 0 0 0.2rem rgba(54,98,90,0.15); }
    .btn-login { background: var(--primary); color: white; border: none; border-radius: 8px; padding: 13px; font-weight: 700; width: 100%; font-size: 1rem; margin-top: 10px; }
    .btn-login:hover { background: #2a4e47; }
    .divider { text-align: center; color: #aaa; margin: 20px 0; font-size: 0.85rem; position: relative; }
    .divider::before, .divider::after { content:''; position: absolute; top: 50%; width: 42%; height: 1px; background: #ddd; }
    .divider::before { left: 0; }
    .divider::after { right: 0; }
    .register-links { display: flex; flex-direction: column; gap: 10px; }
    .btn-outline { border: 2px solid var(--primary); color: var(--primary); background: white; border-radius: 8px; padding: 10px; font-weight: 600; text-align: center; text-decoration: none; font-size: 0.9rem; display: block; }
    .btn-outline:hover { background: var(--primary); color: white; }
    .admin-hint { background: #f8f9fa; border: 1px dashed #ccc; border-radius: 8px; padding: 12px 15px; margin-bottom: 20px; font-size: 0.82rem; color: #666; }
    .alert-success { background: #d4edda; color: #155724; border-radius: 8px; padding: 12px 15px; margin-bottom: 20px; }
    .alert-danger  { background: #f8d7da; color: #721c24; border-radius: 8px; padding: 12px 15px; margin-bottom: 20px; }
</style>

<div class="login-wrapper">
    <div class="login-card">

        <div class="text-center mb-3">
            <span style="background:var(--accent);color:white;padding:5px 18px;border-radius:20px;font-size:0.8rem;font-weight:700;">Elder Care Platform</span>
        </div>
        <div class="login-title">Welcome Back</div>
        <div class="login-sub">Login to your account</div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success">✅ @TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert-danger">❌ @TempData["ErrorMessage"]</div>
        }
        @if (TempData["InfoMessage"] != null)
        {
            <div style="background:#fff3cd;color:#856404;border-radius:8px;padding:12px 15px;margin-bottom:20px;">
                ℹ️ @TempData["InfoMessage"]
            </div>
        }

        <form method="post" asp-action="Login" asp-controller="Home">
            <div class="mb-3">
                <label class="form-label">Email Address</label>
                <input type="email" name="email" class="form-control"
                    placeholder="Enter your email" required>
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="Password" class="form-control"
                    placeholder="Enter your password" required>
            </div>
            <button type="submit" class="btn-login">Login</button>
        </form>

        <div class="divider">New to Elder Care?</div>

        <div class="register-links">
            <a href="/Home/Register" class="btn-outline">
                👤 Register as Customer / Family
            </a>
            <a href="/Home/CaretakerRegister" class="btn-outline">
                🏥 Register as Nurse / Caretaker
            </a>
        </div>

    </div>
</div>