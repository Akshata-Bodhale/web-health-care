@model CareProjct.web.Models.ProductViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "All Registered Caretakers";
}

<div style="background:#f1f5f9; min-height:100vh; padding:36px 0;">
<div class="container-fluid px-4">

    <div style="margin-bottom:28px;">
        <h2 style="font-weight:800; color:#1a3c5e; margin:0 0 4px;">👥 All Registered Caretakers</h2>
        <p style="color:#64748b; margin:0;">Every caretaker who has signed up on the platform</p>
    </div>

    <div style="background:#fff; border-radius:14px; padding:28px; border:1px solid #e2e8f0;">
        @if (!Model.Products.Any())
        {
            <div style="text-align:center; padding:60px; color:#94a3b8;">
                <div style="font-size:2.4rem; margin-bottom:12px;">👤</div>
                <p style="margin:0;">No caretakers registered yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover" style="margin:0;">
                    <thead>
                        <tr>
                            <th>Photo</th>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Contact</th>
                            <th>City</th>
                            <th>Price/Day</th>
                            <th>Status</th>
                            <th>Registered On</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.Products)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.ImagePath))
                                    {
                                        <img src="@c.ImagePath" style="width:45px;height:45px;border-radius:50%;object-fit:cover;" />
                                    }
                                    else
                                    {
                                        <span style="font-size:1.4rem;">👤</span>
                                    }
                                </td>
                                <td style="font-weight:600;">@c.FullName</td>
                                <td>@c.Email</td>
                                <td>@c.ContactNumber</td>
                                <td>@c.City</td>
                                <td>₹@c.Price</td>
                                <td>
                                    @{
                                        var bgColor = c.VerificationStatus == "Approved" ? "#dcfce7" :
                                                      c.VerificationStatus == "Rejected" ? "#fee2e2" : "#fef3c7";
                                        var textColor = c.VerificationStatus == "Approved" ? "#166534" :
                                                        c.VerificationStatus == "Rejected" ? "#991b1b" : "#92400e";
                                    }
                                    <span style="background:@bgColor; color:@textColor; padding:3px 12px; border-radius:20px; font-size:.78rem; font-weight:700;">
                                        @c.VerificationStatus
                                    </span>
                                </td>
                                <td style="color:#64748b; font-size:.85rem;">@c.RegistrationDate.ToString("dd MMM yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

</div>
</div>